{
  "name": "copilot-browser-bridge-standalone",
  "description": "Standalone localhost bridge for GitHub Copilot Browser Bridge",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "build": "tsc -p ./",
    "start": "node ./out/src/index.js",
    "dev": "tsx src/index.ts",
    "test": "vitest run tests/server.test.ts",
    "lint": "eslint \"src/**/*.ts\" \"tests/**/*.ts\" --max-warnings=0"
  },
  "dependencies": {
    "@github/copilot-sdk": "^1.0.0-beta.9"
  },
  "devDependencies": {
    "@eslint/js": "^9.26.0",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^8.31.1",
    "@typescript-eslint/parser": "^8.31.1",
    "eslint": "^9.26.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.0",
    "vitest": "^3.2.4"
  }
}



